# Database (Neon)
DATABASE_URL=postgresql://user:password@host/purrpedia?sslmode=require

# NextAuth
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=https://your-app.vercel.app
NEXTAUTH_SECRET=

# Email (Gmail SMTP)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your@gmail.com
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=PurrPedia <your@gmail.com>

# Temporal (use cloud.temporal.io for production)
TEMPORAL_ADDRESS=your-namespace.your-account.tmprl.cloud:7233
TEMPORAL_NAMESPACE=your-namespace
TEMPORAL_TASK_QUEUE=purrpedia-main
TEMPORAL_API_KEY=

# Cat APIs
THE_CAT_API_KEY=

# Vercel Blob (postcard PNG storage)
BLOB_READ_WRITE_TOKEN=
